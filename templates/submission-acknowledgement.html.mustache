<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:o="urn:schemas-microsoft-com:office:office">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="x-apple-disable-message-reformatting">
    <meta name="format-detection" content="telephone=no, date=no, address=no, email=no, url=no">
    <meta name="color-scheme" content="light dark">
    <meta name="supported-color-schemes" content="light dark">
    <style>
      /* ============ Reset ============ */
      body {
        width: 100% !important;
        height: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
      }

      img {
        height: auto;
        line-height: 100%;
        text-decoration: none;
        border: 0;
        outline: none;
      }

      table {
        border-collapse: separate !important;
      }

      /* ============ Client fixes ============ */
      body,
      table,
      td,
      a {
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
      }

      table,
      td {
        mso-table-lspace: 0;
        mso-table-rspace: 0;
      }

      td {
        mso-line-height-rule: exactly;
      }

      img {
        object-fit: contain;
        max-width: 100%;
        -ms-interpolation-mode: bicubic;
      }

      a[x-apple-data-detectors] {
        font-family: inherit !important;
        font-size: inherit !important;
        font-weight: inherit !important;
        line-height: inherit !important;
        text-decoration: none !important;
        color: inherit !important;
      }

      u + #body a,
      #MessageViewBody a {
        font-family: inherit;
        font-size: inherit;
        font-weight: inherit;
        line-height: inherit;
        text-decoration: none;
        color: inherit;
      }

      /* ============ Core type ============ */
      a {
        color: #2563eb;
        text-decoration: none;
      }

      p {
        margin: 0;
        padding: 0;
      }

      body,
      p,
      td,
      div {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
        color: #1f2328;
      }

      /* ============ Block: email ============ */
      .email__wrap {
        max-width: 600px;
      }

      .email__region {
        padding: 0 16px;
      }

      .email__preview {
        display: none;
        opacity: 0;
        overflow: hidden;
        max-width: 0;
        max-height: 0;
        font-size: 1px;
        line-height: 1px;
        color: #f4f5f7;
      }

      .email__card {
        background: #ffffff;
        border: 1px solid #e8eaed;
        border-radius: 12px;
      }

      .email__card-body {
        padding: 40px 44px;
      }

      .email__wordmark {
        font-size: 16px;
        font-weight: 600;
        letter-spacing: .02em;
        color: #5b636d;
      }

      .email__eyebrow {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .14em;
        color: #2563eb;
        text-transform: uppercase;
        line-height: 16px;
      }

      .email__title {
        font-size: 23px;
        font-weight: 700;
        letter-spacing: -.01em;
        line-height: 30px;
        color: #14171a;
      }

      .email__meta {
        font-size: 13px;
        line-height: 20px;
        color: #7a828c;
      }

      .email__intro {
        font-size: 16px;
        line-height: 26px;
        color: #1f2328;
      }

      .email__field {
        padding: 16px 0;
        border-top: 1px solid #f0f1f4;
      }

      .email__field-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: .07em;
        color: #9aa0a8;
        text-transform: uppercase;
        line-height: 14px;
      }

      .email__field-value {
        font-size: 15px;
        line-height: 25px;
        color: #1f2328;
        white-space: pre-wrap;
      }

      .email__contact {
        font-size: 13px;
        line-height: 20px;
        color: #5b636d;
      }

      .email__footer {
        font-size: 12px;
        line-height: 18px;
        color: #a2a8b0;
        text-align: center;
      }

      /* ============ Responsive ============ */
      @media screen and (max-width: 600px) {
        .email__wrap {
          width: 100% !important;
          max-width: 100% !important;
        }

        .email__card-body {
          padding: 28px 24px !important;
        }
      }

      /* ============ Dark mode (Apple Mail / iOS; Outlook keeps light) ============ */
      @media (prefers-color-scheme: dark) {
        .email {
          background: #0e0f11 !important;
        }

        .email__card {
          background: #17191c !important;
          border-color: #26292e !important;
        }

        .email__wordmark {
          color: #8b929b !important;
        }

        .email__eyebrow {
          color: #6f9bff !important;
        }

        .email__title {
          color: #eef0f3 !important;
        }

        .email__meta {
          color: #8b929b !important;
        }

        .email__intro {
          color: #dfe3e8 !important;
        }

        .email__field {
          border-color: #23262a !important;
        }

        .email__field-label {
          color: #7b828b !important;
        }

        .email__field-value {
          color: #dfe3e8 !important;
        }

        .email__contact {
          color: #9aa1ab !important;
        }

        .email__footer {
          color: #6b727b !important;
        }
      }
    </style>
    <title>{{heading}}</title>
    <!--[if (gte mso 9)|(IE)]>
      <xml>
        <o:OfficeDocumentSettings>
          <o:AllowPNG />
          <o:PixelsPerInch>96</o:PixelsPerInch>
        </o:OfficeDocumentSettings>
      </xml>
      <style>
        * {
          font-family: 'Segoe UI', Helvetica, Arial, sans-serif !important;
        }

        a {
          text-decoration: none;
        }
      </style>
    <![endif]-->
  </head>
  <body id="body" class="email" style="margin:0; padding:0; background:#f4f5f7;">
    <div class="email__preview">{{heading}}{{#siteHost}} · {{siteHost}}{{/siteHost}}</div>
    <table border="0" cellpadding="0" cellspacing="0" width="100%" role="presentation" bgcolor="#f4f5f7" class="email" style="background: #f4f5f7;">
      {{#brandName}}
      <tr>
        <td align="center" class="email__region" style="padding:24px 16px 4px;">
          <!--[if (gte mso 9)|(IE)]>
            <table align="center" border="0" cellpadding="0" cellspacing="0" width="600" role="presentation">
              <tr>
                <td align="left" valign="top" width="600">
          <![endif]-->
          <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" class="email__wrap" role="presentation">
            <tr>
              <td align="left" style="padding: 8px 4px;">
                <span class="email__wordmark">{{brandName}}</span>
              </td>
            </tr>
          </table>
          <!--[if (gte mso 9)|(IE)]>
                </td>
              </tr>
            </table>
          <![endif]-->
        </td>
      </tr>
      {{/brandName}}
      <tr>
        <td align="center" class="email__region" style="padding: 12px 16px;">
          <!--[if (gte mso 9)|(IE)]>
            <table align="center" border="0" cellpadding="0" cellspacing="0" width="600" role="presentation">
              <tr>
                <td align="center" valign="top" width="600">
          <![endif]-->
          <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" class="email__wrap email__card" role="presentation" bgcolor="#ffffff" style="background: #ffffff; border: 1px solid #e8eaed; border-radius:12px;">
            <tr>
              <td class="email__card-body" style="padding: 40px 44px;">
                <div class="email__eyebrow">{{eyebrow}}</div>
                <div class="email__title" style="padding-top: 14px;">{{heading}}</div>
                <div class="email__meta" style="padding-top: 6px;">{{#formName}}{{formName}}{{#submittedAt}} &nbsp;·&nbsp; {{/submittedAt}}{{/formName}}{{submittedAt}}</div>
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td height="22" style="font-size: 0; line-height: 22px;">&nbsp;</td>
                  </tr>
                </table>
                {{#greeting}}
                <div class="email__intro" style="padding-bottom: 12px;">{{greeting}}</div>
                {{/greeting}}
                <div class="email__intro">{{message}}</div>
                {{#hasFields}}
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td height="26" style="font-size: 0; line-height: 26px;">&nbsp;</td>
                  </tr>
                </table>
                {{/hasFields}}
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  {{#fields}}
                  <tr>
                    <td class="email__field" style="padding: 16px 0; border-top: 1px solid #f0f1f4;">
                      <div class="email__field-label" style="padding-bottom: 5px;">{{label}}</div>
                      <div class="email__field-value">{{value}}</div>
                    </td>
                  </tr>
                  {{/fields}}
                </table>
                {{#attachments}}
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td style="padding: 16px 0 0; border-top: 1px solid #f0f1f4;">
                      <div class="email__field-label" style="padding-bottom: 5px;">{{attachmentsLabel}}</div>
                    </td>
                  </tr>
                  {{#items}}
                  <tr>
                    <td style="padding: 6px 0 0;">
                      <a href="{{url}}" style="color: #2563eb; font-size: 15px;">{{name}}</a>{{#size}}<span style="color: #9ca3af; font-size: 13px;"> · {{size}}</span>{{/size}}
                    </td>
                  </tr>
                  {{/items}}
                </table>
                {{/attachments}}
                {{#hasContact}}
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  {{^hasBodyItems}}
                  <tr>
                    <td height="24" style="font-size: 0; line-height: 24px;">&nbsp;</td>
                  </tr>
                  {{/hasBodyItems}}
                  <tr>
                    <td class="email__contact" style="border-top: 1px solid #f0f1f4; padding-top: 24px;">{{#brandName}}<div>{{brandName}}</div>{{/brandName}}{{#contactEmail}}<div><a href="mailto:{{contactEmail}}" style="color: #2563eb;">{{contactEmail}}</a></div>{{/contactEmail}}{{#contactPhone}}<div><a href="tel:{{contactPhoneHref}}" style="color: #2563eb;">{{contactPhone}}</a></div>{{/contactPhone}}{{#contactAddress}}<div>{{contactAddress}}</div>{{/contactAddress}}</td>
                  </tr>
                </table>
                {{/hasContact}}
              </td>
            </tr>
          </table>
          <!--[if (gte mso 9)|(IE)]>
                </td>
              </tr>
            </table>
          <![endif]-->
        </td>
      </tr>
      <tr>
        <td align="center" class="email__region" style="padding: 8px 16px 32px;">
          <!--[if (gte mso 9)|(IE)]>
            <table align="center" border="0" cellpadding="0" cellspacing="0" width="600" role="presentation">
              <tr>
                <td align="center" valign="top" width="600">
          <![endif]-->
          <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" class="email__wrap" role="presentation">
            <tr>
              <td align="center" style="padding: 16px 8px;">
                <div class="email__footer">{{footerText}}{{#siteURL}}<br><a href="{{siteURL}}" target="_blank" rel="noopener noreferrer" style="color: #a2a8b0;">{{siteURL}}</a>{{/siteURL}}</div>
              </td>
            </tr>
          </table>
          <!--[if (gte mso 9)|(IE)]>
                </td>
              </tr>
            </table>
          <![endif]-->
        </td>
      </tr>
    </table>
  </body>
</html>
