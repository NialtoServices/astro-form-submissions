{
  "name": "@nialto-services/astro-form-submissions",
  "version": "0.1.1",
  "type": "module",
  "description": "Form submissions toolkit for Astro sites.",
  "license": "MIT",
  "packageManager": "pnpm@10.30.2",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./form": {
      "types": "./dist/client/form.d.ts",
      "import": "./dist/client/form.js"
    }
  },
  "imports": {
    "#*": {
      "types": "./src/*",
      "default": "./dist/*"
    }
  },
  "scripts": {
    "build": "node scripts/generate-email-template-sources.mjs && rm -rf dist && tsc -p tsconfig.build.json",
    "check": "node scripts/generate-email-template-sources.mjs && tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "node scripts/generate-email-template-sources.mjs && vitest run",
    "prepublishOnly": "pnpm build",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "mustache": "^4.2.0",
    "postmark": "^4.0.7"
  },
  "peerDependencies": {
    "astro": "^7.0.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/mustache": "^4.2.6",
    "astro": "^7.0.4",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "msw": "^2.15.0",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
